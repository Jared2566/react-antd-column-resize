{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES5",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ESNext", "ES2015", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx"],
  "exclude": ["node_modules", "dist"]
}
